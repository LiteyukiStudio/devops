API_ADDR=:8080
APP_ENV=development
DATABASE_URL=postgres://devops:devops@localhost:5432/devops?sslmode=disable
REDIS_ADDR=localhost:6379
PUBLIC_BASE_URL=http://localhost:8080

# Optional Casdoor / generic OIDC bootstrap.
# Client secret is read through clientSecretRef, so the provider stores only env:OIDC_CLIENT_SECRET.
CASDOOR_ISSUER_URL=
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET_REF=env:OIDC_CLIENT_SECRET
OIDC_CLIENT_SECRET=
