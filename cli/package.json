{
  "name": "@liteyukistudio/luna-cli",
  "version": "0.1.0",
  "description": "Command-line client for Luna DevOps",
  "type": "module",
  "bin": {
    "luna": "bin/luna.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LiteyukiStudio/devops.git",
    "directory": "cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:binary": "bun build src/entry.ts --compile --outfile dist/luna",
    "dev": "tsx src/entry.ts",
    "lint": "eslint src tests",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "commander": "^14.0.3",
    "i18next": "^26.3.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@luna-devops/api-client": "workspace:*",
    "@luna-devops/api-contract": "workspace:*",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "tsx": "^4.21.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.10"
  }
}
