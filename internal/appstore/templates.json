[
  {
    "id": "redis",
    "slug": "redis",
    "name": "Redis",
    "description": "In-memory data store for cache, queues, and lightweight coordination.",
    "category": "database",
    "icon": "/app-templates/icons/redis.svg",
    "image": "redis:7-alpine",
    "version": "7-alpine",
    "servicePort": 6379,
    "defaultReplicas": 1,
    "defaultCPU": "500m",
    "defaultMemory": "512Mi",
    "dataRetentionEnabled": true,
    "dataMountPath": "/data",
    "dataCapacity": "1Gi",
    "values": []
  },
  {
    "id": "postgresql",
    "slug": "postgres",
    "name": "PostgreSQL",
    "description": "Relational database for application data, metadata, and transactional workloads.",
    "category": "database",
    "icon": "/app-templates/icons/postgresql.svg",
    "image": "postgres:16-alpine",
    "version": "16-alpine",
    "servicePort": 5432,
    "defaultReplicas": 1,
    "defaultCPU": "1",
    "defaultMemory": "1Gi",
    "dataRetentionEnabled": true,
    "dataMountPath": "/var/lib/postgresql/data",
    "dataCapacity": "5Gi",
    "env": {
      "POSTGRES_USER": "{{username}}",
      "POSTGRES_DB": "{{database}}"
    },
    "secretEnv": {
      "POSTGRES_PASSWORD": "{{password}}"
    },
    "values": [
      { "key": "username", "label": "Username", "default": "app", "required": true },
      { "key": "database", "label": "Database", "default": "app", "required": true },
      { "key": "password", "label": "Password", "secret": true, "autoGenerate": true, "required": true }
    ]
  },
  {
    "id": "mysql",
    "slug": "mysql",
    "name": "MySQL",
    "description": "Classic relational database with a simple single-container setup.",
    "category": "database",
    "icon": "/app-templates/icons/mysql.svg",
    "image": "mysql:8.4",
    "version": "8.4",
    "servicePort": 3306,
    "defaultReplicas": 1,
    "defaultCPU": "1",
    "defaultMemory": "1Gi",
    "dataRetentionEnabled": true,
    "dataMountPath": "/var/lib/mysql",
    "dataCapacity": "5Gi",
    "env": {
      "MYSQL_DATABASE": "{{database}}",
      "MYSQL_USER": "{{username}}"
    },
    "secretEnv": {
      "MYSQL_ROOT_PASSWORD": "{{rootPassword}}",
      "MYSQL_PASSWORD": "{{password}}"
    },
    "values": [
      { "key": "database", "label": "Database", "default": "app", "required": true },
      { "key": "username", "label": "Username", "default": "app", "required": true },
      { "key": "rootPassword", "label": "Root password", "secret": true, "autoGenerate": true, "required": true },
      { "key": "password", "label": "Password", "secret": true, "autoGenerate": true, "required": true }
    ]
  },
  {
    "id": "rabbitmq",
    "slug": "rabbitmq",
    "name": "RabbitMQ",
    "description": "Message broker for asynchronous jobs, events, and lightweight queues.",
    "category": "middleware",
    "icon": "/app-templates/icons/rabbitmq.svg",
    "image": "rabbitmq:3-management-alpine",
    "version": "3-management-alpine",
    "servicePort": 5672,
    "defaultReplicas": 1,
    "defaultCPU": "500m",
    "defaultMemory": "512Mi",
    "dataRetentionEnabled": true,
    "dataMountPath": "/var/lib/rabbitmq",
    "dataCapacity": "2Gi",
    "env": {
      "RABBITMQ_DEFAULT_USER": "{{username}}"
    },
    "secretEnv": {
      "RABBITMQ_DEFAULT_PASS": "{{password}}"
    },
    "values": [
      { "key": "username", "label": "Username", "default": "app", "required": true },
      { "key": "password", "label": "Password", "secret": true, "autoGenerate": true, "required": true }
    ]
  }
]
