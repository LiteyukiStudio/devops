      }
    ],
    "values": [
      { "key": "rpcSecret", "label": "RPC secret", "secret": true, "autoGenerate": true, "required": true },
      { "key": "adminToken", "label": "Admin token", "secret": true, "autoGenerate": true, "required": true },
      { "key": "metricsToken", "label": "Metrics token", "secret": true, "autoGenerate": true, "required": true }
    ]
